    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "colorette": "2.0.20",
    "dayjs": "1.11.20",
    "firebase": "12.11.0",
    "google-auth-library": "10.6.2",
    "i18next": "25.8.20",
    "i18next-browser-languagedetector": "8.2.1",
    "input-otp": "1.4.2",
