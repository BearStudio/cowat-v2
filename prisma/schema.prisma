// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/server/db/generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum CommuteType {
  ROUND
  ONEWAY
}

enum CommuteStatus {
  UNKNOWN
  ON_TIME
  DELAYED
}

enum DriverStopStatus {
  UNKNOWN
  HERE
}

enum RequestStatus {
  REQUESTED
  ACCEPTED
  REFUSED
  CANCELED
}

enum StopStatus {
  UNKNOWN
  ON_TIME
  AWAITING
  DELAYED
}

enum TripType {
  ROUND
  ONEWAY
  RETURN
}

enum NotificationChannel {
  SLACK
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  phone         String?
  autoAccept    Boolean  @default(false)

  role        UserRole?
  banned      Boolean?
  banReason   String?
  banExpires  DateTime?
  onboardedAt DateTime?

  notificationPreferences  NotificationPreference[]

  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
  @@index([identifier])
}

model Location {
  id             String         @id @default(cuid())
  name           String
  address        String
  latitude       Float?
  longitude      Float?
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  memberId       String
  member         Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  stops          Stop[]
  templateStops  TemplateStop[]

  @@index([memberId])
  @@map("location")
}

model Commute {
  id             String        @id @default(cuid())
  date           DateTime      @db.Date
  seats          Int
  type           CommuteType
  status         CommuteStatus @default(UNKNOWN)
  delay          Int?
  comment        String?
  isDeleted      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  driverMemberId String
  driver         Member        @relation("CommuteDriver", fields: [driverMemberId], references: [id], onDelete: Cascade)
  stops          Stop[]

  @@index([driverMemberId, date])
  @@map("commute")
}

model Stop {
  id           String              @id @default(cuid())
  order        Int                 @default(0)
  outwardTime  String
  inwardTime   String?
  driverStatus DriverStopStatus    @default(UNKNOWN)
  isDeleted    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  commuteId    String
  commute      Commute             @relation(fields: [commuteId], references: [id], onDelete: Cascade)
  locationId   String
  location     Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  passengers   PassengersOnStops[]

  @@index([commuteId])
  @@map("stop")
}

model PassengersOnStops {
  id          String        @id @default(cuid())
  status      RequestStatus @default(REQUESTED)
  stopStatus  StopStatus    @default(UNKNOWN)
  tripType    TripType
  delay       Int?
  comment     String?
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  passengerMemberId String
  passenger         Member    @relation("BookingPassenger", fields: [passengerMemberId], references: [id], onDelete: Cascade)
  stopId            String
  stop              Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([passengerMemberId, stopId])
  @@index([passengerMemberId])
  @@index([stopId])
  @@map("passengers_on_stops")
}

model CommuteTemplate {
  id             String         @id @default(cuid())
  name           String
  seats          Int
  type           CommuteType
  comment        String?
  isDeleted      Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  driverMemberId String
  driver         Member         @relation("TemplateDriver", fields: [driverMemberId], references: [id], onDelete: Cascade)
  stops          TemplateStop[]

  @@index([driverMemberId])
  @@map("commute_template")
}

model TemplateStop {
  id          String          @id @default(cuid())
  order       Int             @default(0)
  outwardTime String
  inwardTime  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  templateId  String
  template    CommuteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@map("template_stop")
}

model NotificationPreference {
  id        String              @id @default(cuid())
  enabled   Boolean             @default(true)
  channel   NotificationChannel
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@map("notification_preference")
}

model Organization {
  id               String            @id
  name             String
  slug             String
  logo             String?
  createdAt        DateTime
  metadata         String?
  members          Member[]
  invitations      Invitation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  locations           Location[]
  drivenCommutes      Commute[]           @relation("CommuteDriver")
  drivenTemplates     CommuteTemplate[]   @relation("TemplateDriver")
  passengerBookings   PassengersOnStops[] @relation("BookingPassenger")

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}
