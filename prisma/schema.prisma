// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/server/db/generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum CommuteType {
  ROUND
  ONEWAY
}

enum CommuteStatus {
  UNKNOWN
  ON_TIME
  DELAYED
}

enum DriverStopStatus {
  UNKNOWN
  HERE
}

enum RequestStatus {
  REQUESTED
  ACCEPTED
  REFUSED
  CANCELED
}

enum StopStatus {
  UNKNOWN
  ON_TIME
  AWAITING
  DELAYED
}

enum TripType {
  ROUND
  ONEWAY
  RETURN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  phone         String?
  autoAccept    Boolean  @default(false)
  slackMemberId String?

  role        UserRole?
  banned      Boolean?
  banReason   String?
  banExpires  DateTime?
  onboardedAt DateTime?

  locations         Location[]
  commutes          Commute[]
  passengerBookings PassengersOnStops[]
  commuteTemplates  CommuteTemplate[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Location {
  id            String         @id @default(cuid())
  name          String
  address       String
  latitude      Float
  longitude     Float
  isDeleted     Boolean        @default(false) @map("is_deleted")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  userId        String         @map("user_id")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops         Stop[]
  templateStops TemplateStop[]

  @@index([userId])
  @@map("location")
}

model Commute {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  seats       Int
  type        CommuteType
  status      CommuteStatus @default(UNKNOWN)
  delay       Int?
  outwardTime String        @map("outward_time")
  inwardTime  String?       @map("inward_time")
  comment     String?
  isDeleted   Boolean       @default(false) @map("is_deleted")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  driverId    String        @map("driver_id")
  driver      User          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  stops       Stop[]

  @@index([driverId, date])
  @@map("commute")
}

model Stop {
  id           String              @id @default(cuid())
  order        Int                 @default(0)
  time         String
  driverStatus DriverStopStatus    @default(UNKNOWN) @map("driver_status")
  isDeleted    Boolean             @default(false) @map("is_deleted")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  commuteId    String              @map("commute_id")
  commute      Commute             @relation(fields: [commuteId], references: [id], onDelete: Cascade)
  locationId   String              @map("location_id")
  location     Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  passengers   PassengersOnStops[]

  @@index([commuteId])
  @@map("stop")
}

model PassengersOnStops {
  id          String        @id @default(cuid())
  status      RequestStatus @default(REQUESTED)
  stopStatus  StopStatus    @default(UNKNOWN) @map("stop_status")
  tripType    TripType      @map("trip_type")
  delay       Int?
  comment     String?
  isDeleted   Boolean       @default(false) @map("is_deleted")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  passengerId String        @map("passenger_id")
  passenger   User          @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  stopId      String        @map("stop_id")
  stop        Stop          @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([passengerId, stopId])
  @@index([passengerId])
  @@index([stopId])
  @@map("passengers_on_stops")
}

model CommuteTemplate {
  id          String         @id @default(cuid())
  name        String
  seats       Int
  type        CommuteType
  outwardTime String         @map("outward_time")
  inwardTime  String?        @map("inward_time")
  comment     String?
  isDeleted   Boolean        @default(false) @map("is_deleted")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  driverId    String         @map("driver_id")
  driver      User           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  stops       TemplateStop[]

  @@map("commute_template")
}

model TemplateStop {
  id         String          @id @default(cuid())
  order      Int             @default(0)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  templateId String          @map("template_id")
  template   CommuteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  locationId String          @map("location_id")
  location   Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@map("template_stop")
}
